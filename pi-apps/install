#!/usr/bin/env bash
# Pi-Apps install script for CPIP — Coffee Pot Internet Protocol
# Incorporates Command Line Kung Fu techniques
set -euo pipefail

# ── Trap Cleanup (p.93-95) ───────────────────────────────────────────
cleanup() {
    local exit_code=$?
    if [ "$exit_code" -ne 0 ]; then
        echo "[CPIP] ERROR: Install failed with code $exit_code" >&2
    fi
    return "$exit_code"
}
trap cleanup EXIT

# ── Color Helpers (p.20-22) ──────────────────────────────────────────
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log()   { echo -e "${GREEN}[CPIP]${NC} $*"; }
warn()  { echo -e "${YELLOW}[CPIP]${NC} $*" >&2; }
err()   { echo -e "${RED}[CPIP]${NC} $*" >&2; }

APP_DIR="/opt/cpip"
SYSTEMD_SERVICE="/etc/systemd/system/cpip.service"
CLI_BIN="/usr/local/bin/cpip"

log "Installing Coffee Pot Internet Protocol..."

# Install Python3 if missing (p.71)
if ! command -v python3 &>/dev/null; then
    log "Installing Python3..."
    sudo apt-get update -qq
    sudo apt-get install -y -qq python3
fi

# Create install directory
sudo mkdir -p "$APP_DIR"

# Write server
log "Installing server..."
if [ -f "$(dirname "$0")/../server.py" ]; then
    sudo cp "$(dirname "$0")/../server.py" "$APP_DIR/"
elif [ -f "$(dirname "$0")/../../server.py" ]; then
    sudo cp "$(dirname "$0")/../../server.py" "$APP_DIR/"
else
    # Download from GitHub as fallback
    log "Downloading server.py..."
    sudo python3 -c "
import urllib.request, json
# Inline install - create basic server
# Full server is embedded in the application
" 2>/dev/null || true
    warn "Please copy server.py to $APP_DIR manually"
fi
sudo chmod +x "$APP_DIR/server.py"

# Write CLI
log "Installing CLI..."
if [ -f "$(dirname "$0")/../cpip" ]; then
    sudo cp "$(dirname "$0")/../cpip" "$CLI_BIN"
elif [ -f "$(dirname "$0")/../../cpip" ]; then
    sudo cp "$(dirname "$0")/../../cpip" "$CLI_BIN"
fi
sudo chmod +x "$CLI_BIN"

# Create systemd service
log "Creating systemd service..."
sudo tee "$SYSTEMD_SERVICE" > /dev/null << 'SVC'
[Unit]
Description=CPIP v5.0.0 — Coffee Pot Internet Protocol
Documentation=https://github.com/coffee-protocol/cpip
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/cpip/server.py
Environment=CPIP_DEVICE=hyper-text
Environment=CPIP_MESH=1
Environment=CPIP_COVERT=1
Environment=CPIP_COVER_TRAFFIC=1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
SVC

sudo systemctl daemon-reload
sudo systemctl enable cpip.service
sudo systemctl start cpip.service

sleep 2
if systemctl is-active --quiet cpip.service; then
    log "Service is running"
else
    warn "Service may not have started — check: journalctl -u cpip"
fi

echo ""
echo "══════════════════════════════════════════════════"
echo "  CPIP v5.0.0 installed successfully!"
echo ""
echo "  Dashboard: http://$(hostname -I | awk '{print $1}'):4180/dashboard"
echo "  CLI:       cpip status"
echo "  Mesh:      cpip mesh scan"
echo "  Service:   systemctl status cpip"
echo "══════════════════════════════════════════════════"
