#!/usr/bin/env bash
# Pi-Apps uninstall script for CPIP — Coffee Pot Internet Protocol
# Incorporates Command Line Kung Fu techniques
set -euo pipefail

# ── Trap Cleanup (p.93-95) ───────────────────────────────────────────
cleanup() {
    local exit_code=$?
    if [ "$exit_code" -ne 0 ]; then
        echo -e "\033[0;31m[CPIP] ERROR: Uninstall failed with code $exit_code\033[0m" >&2
    fi
    return "$exit_code"
}
trap cleanup EXIT

echo "[CPIP] Uninstalling Coffee Pot Internet Protocol..."

# Stop and disable service
if systemctl is-active --quiet cpip.service 2>/dev/null; then
    sudo systemctl stop cpip.service
fi
if systemctl is-enabled --quiet cpip.service 2>/dev/null; then
    sudo systemctl disable cpip.service
fi

# Remove service file
sudo rm -f /etc/systemd/system/cpip.service
sudo systemctl daemon-reload

# Remove app files
sudo rm -rf /opt/cpip

# Remove CLI
sudo rm -f /usr/local/bin/cpip

echo "[CPIP] Uninstalled successfully."
echo "[CPIP] Brew history and mesh data have been lost."
echo "[CPIP] The mesh will continue without this node."
