#!/usr/bin/env bash
set -euo pipefail

# ── Color Helpers (Command Line Kung Fu, p.20-22) ────────────────────
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly NC='\033[0m'

info()  { echo -e "${CYAN}[*]${NC} $*"; }
ok()    { echo -e "${GREEN}[OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*" >&2; }
err()   { echo -e "${RED}[X]${NC} $*" >&2; }
die()   { err "$*"; exit 1; }

# ── Temp File Handling with mktemp + trap cleanup (p.93-95) ──────────
TMPDIR="${TMPDIR:-/tmp}"
CPIP_TMP=""
cleanup() { [ -n "$CPIP_TMP" ] && rm -rf "$CPIP_TMP"; }
trap cleanup EXIT
mktmpdir() { CPIP_TMP=$(mktemp -d "${TMPDIR}/cpip.XXXXXX"); }

# ── Clipboard Integration (p.19-20) ─────────────────────────────────
clip_copy() {
    if command -v xclip &>/dev/null; then
        echo -n "$1" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        echo -n "$1" | xsel --clipboard --input
    elif command -v pbcopy &>/dev/null; then
        echo -n "$1" | pbcopy
    elif [ -n "$WAYLAND_DISPLAY" ] && command -v wl-copy &>/dev/null; then
        echo -n "$1" | wl-copy
    else
        return 1
    fi
}

clip_paste() {
    if command -v xclip &>/dev/null; then
        xclip -selection clipboard -out
    elif command -v xsel &>/dev/null; then
        xsel --clipboard --output
    elif command -v pbpaste &>/dev/null; then
        pbpaste
    elif [ -n "$WAYLAND_DISPLAY" ] && command -v wl-paste &>/dev/null; then
        wl-paste
    else
        return 1
    fi
}

# ── Argument Validation (p.7-8) ──────────────────────────────────────
require_args() {
    local need=$1; shift
    local have=$#
    [ "$have" -lt "$need" ] && die "Missing arguments. Expected $need, got $have.\nRun 'cpip help' for usage."
}

# ── Progress Spinner (p.180-182) ─────────────────────────────────────
spinner() {
    local pid=$1
    local msg="${2:-Working}"
    local sp='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CYAN}%s${NC} %s..." "${sp:i++%10:1}" "$msg"
        sleep 0.1
    done
    printf "\r  ${GREEN}✓${NC} %s... done\n" "$msg"
}

